      },
      "title": {
        "cn": "肇庆广宁 Maca 音乐客厅 Live",
        "en": "Maca Music Living Room · Guangning"
      },
      "summary": {
        "cn": "Maca 音乐客厅 Live 扩声系统搭建与调试，围绕中小型音乐空间的清晰度、覆盖均匀度、低频控制和长期稳定运营进行系统优化。",
        "en": "Live sound system setup and tuning for Maca Music Living Room, optimizing clarity, coverage, low-frequency control and long-term reliability."
      },
      "background": {
        "cn": "Maca 音乐客厅是以 live 演出、音乐交流和现场氛围为核心的音乐空间。",
        "en": "Maca Music Living Room is a venue focused on live performances, music community and on-site atmosphere."
      },
      "services": {
        "cn": "【待补充】",
