# 本地开发 — 复制为 .env.local 后按需修改

# 方式 A：电脑本机（默认，可留空 — dev 模式走 Vite /api 代理）
# VITE_API_URL=http://localhost:3001

# 方式 B：手机直连 API（可选，一般不需要 — 见 docs/LOCAL_NETWORK_PREVIEW.md）
# VITE_API_URL=http://192.168.x.x:3001

# —— Vercel 生产前台（构建时注入）——
# VITE_API_URL=https://api.yuyakang.top

PORT=3001
HOST=0.0.0.0
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# —— Render API_ONLY 模式（见 docs/DEPLOY_VERCEL_RENDER_FREE.md）——
# API_ONLY=true
# PUBLIC_SITE_URL=https://www.yuyakang.top
# ALLOWED_ORIGINS=https://yuyakang.top,https://www.yuyakang.top

# —— Admin Auth (Round 5.3) ——
# 生成密码 hash: node scripts/generate-admin-password-hash.mjs "your-password"
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=replace-with-generated-hash
ADMIN_SESSION_SECRET=replace-with-random-secret
ADMIN_SESSION_MAX_AGE=86400000

# 验证脚本用（不要提交真实密码到仓库）
# ADMIN_TEST_USERNAME=admin
# ADMIN_TEST_PASSWORD=your-local-test-password